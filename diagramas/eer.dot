
digraph EER {
  graph [rankdir=LR, bgcolor="white", splines=ortho, nodesep=0.7, ranksep=0.9];
  node [fontname="DejaVu Sans", fontsize=10, shape=record, style="rounded,filled", fillcolor="#F7F7F7"];
  edge [fontname="DejaVu Sans", fontsize=9, color="#333333"];

  Departamento [label="{DEPARTAMENTO|PK id_departamento\lnombre\ledificio\ltelefono\l}"];
  Carrera [label="{CARRERA|PK id_carrera\lnombre\lnivel\lcreditos_totales\lFK id_departamento\l}"];
  Profesor [label="{PROFESOR|PK id_profesor\lnombre\lcorreo\lgrado\lsalario\lFK id_departamento\lFK id_supervisor\l}"];
  Estudiante [label="{ESTUDIANTE|PK id_estudiante\lnombre\lcorreo\ledad\lsemestre\lpromedio\lFK id_carrera\lFK id_tutor\l}"];
  Curso [label="{CURSO|PK id_curso\lnombre\lcreditos\ltipo\larea\lFK id_departamento\l}"];
  Aula [label="{AULA|PK id_aula\lclave\ledificio\lcapacidad\ltipo\ltiene_proyector\l}"];
  Grupo [label="{GRUPO|PK id_grupo\lFK id_curso\lFK id_profesor\lFK id_aula\lperiodo\lcupo\lhorario\l}"];
  Inscripcion [label="{INSCRIPCION|PK id_inscripcion\lFK id_estudiante\lFK id_grupo\lfecha\lcalificacion\lestado\l}"];

  Departamento -> Carrera [label="1:N ofrece"];
  Departamento -> Profesor [label="1:N adscrito"];
  Departamento -> Curso [label="1:N administra"];
  Carrera -> Estudiante [label="1:N pertenece"];
  Profesor -> Estudiante [label="1:N tutor", style=dashed];
  Profesor -> Profesor [label="supervisa", style=dashed];
  Curso -> Grupo [label="1:N se abre"];
  Profesor -> Grupo [label="1:N imparte"];
  Aula -> Grupo [label="1:N se usa"];
  Estudiante -> Inscripcion [label="1:N realiza"];
  Grupo -> Inscripcion [label="1:N recibe"];
}
